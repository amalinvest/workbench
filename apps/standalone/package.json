{
  "name": "@getworkbench/standalone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --packages external",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getworkbench/bun": "workspace:*",
    "bullmq": "^5.71.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.2"
  }
}
