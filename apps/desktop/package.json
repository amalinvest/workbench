{
  "name": "@workbench/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "concurrently -k -n vite,sidecar,tauri -c blue,green,magenta \"bun run dev:vite\" \"bun run dev:sidecar\" \"bun run dev:tauri\"",
    "dev:vite": "vite --port 5173",
    "dev:sidecar": "bun run sidecar/build.ts --watch",
    "// dev:tauri": "Redirect stdin from /dev/null — `tauri dev` exits when its stdin closes (EOF), which happens immediately under concurrently. Detaching keeps the dev loop alive.",
    "dev:tauri": "tauri dev < /dev/null",
    "build": "bun run build:ui && bun run build:sidecar && bun run build:tauri",
    "build:ui": "vite build",
    "build:sidecar": "bun run sidecar/build.ts",
    "build:sidecar:all": "bun run sidecar/build.ts --all",
    "build:tauri": "tauri build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getworkbench/core": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bullmq": "^5.71.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "^1.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
