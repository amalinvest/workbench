{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workbench",
  "version": "0.1.0",
  "identifier": "dev.getworkbench.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build:ui",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 },
        "backgroundColor": "#0a0a0a",
        "devtools": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' http://127.0.0.1:* ipc: http://ipc.localhost",
        "img-src": "'self' data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "© 2026 Workbench contributors",
    "shortDescription": "Open-source BullMQ dashboard for the desktop.",
    "longDescription": "Workbench is a desktop client for BullMQ queues. Point it at a Redis URL and inspect runs, schedulers, flows, and metrics with no infrastructure to deploy.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../dist-sidecar/workbench-sidecar"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": []
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_BEFORE_RELEASE_RUN_tauri_signer_generate",
      "endpoints": [
        "https://github.com/pontusab/workbench/releases/latest/download/latest.json"
      ]
    }
  }
}
