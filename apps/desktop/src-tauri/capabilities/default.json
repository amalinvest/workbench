{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main Workbench desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "../dist-sidecar/workbench-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "dialog:default",
    "os:default",
    "process:default",
    "store:default",
    "updater:default"
  ]
}
