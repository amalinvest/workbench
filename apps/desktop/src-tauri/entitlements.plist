<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Entitlements applied to the outer Workbench.app bundle. The sidecar
    binary carries its own entitlements (see sidecar-entitlements.plist)
    that are applied by the CI codesign step BEFORE tauri-action bundles
    it, so we keep this file as narrow as possible.
  -->

  <!-- Outbound TCP for the IPC loopback to the sidecar and the updater. -->
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
